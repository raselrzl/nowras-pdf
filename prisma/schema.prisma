generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
  ACCOUNTANT
  GUARDIAN
  ADMISSION
  COMMITTEE
  USER
}


model Student {
  id         String   @id @default(uuid())
  name       String
  email      String?
  password   String
  roll       String?
  className  String?
  section    String?

  guardianId String?
  guardian   Guardian? @relation(fields: [guardianId], references: [id])

  createdAt  DateTime @default(now())
}



model Teacher {
  id        String   @id @default(uuid())
  name      String
  email     String
  password  String
  subject   String?
  phone     String?
  address   String?

  createdAt DateTime @default(now())
}


model Guardian {
  id        String   @id @default(uuid())
  name      String
  email     String
  password  String
  phone     String?
  students  Student[]

  createdAt DateTime @default(now())
}






model Accountant {
  id     String @id @default(uuid())
  name   String?
}

model Committee {
  id       String @id @default(uuid())
  name     String?
  position String?
}

model Admission {
  id           String   @id @default(uuid())
  studentName  String
  email        String
  status       AdmissionStatus @default(PENDING)
  createdAt    DateTime @default(now())
}

enum AdmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model Pdf {
  id        String   @id @default(cuid())
  name      String
  url       String
  createdAt DateTime @default(now())
}